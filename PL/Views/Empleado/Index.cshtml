    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model List<ML.Empleado>

@{
    ViewData["Title"] = "Empleados";
}

<h2>Lista de Empleados</h2>

<button class="btn btn-success mb-3" onclick="abrirModalAgregar()">
    Agregar Empleado
</button>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Edad</th>
            <th>Departamento</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.IdEmpleado</td>
                    <td>@emp.Nombre</td>
                    <td>@emp.Edad</td>
                    <td>@emp.Departamento?.Nombre</td>
                    <td class="text-end">
                        <button class="btn btn-warning btn-sm"
                                onclick="abrirModalEditar(@emp.IdEmpleado, '@emp.Nombre', @emp.Edad, @emp.Departamento?.IdDepartamento)">
                            Editar
                        </button>

                        <a asp-action="Delete"
                           asp-route-id="@emp.IdEmpleado"
                           class="btn btn-danger btn-sm">
                            Eliminar
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">
                    No hay empleados registrados
                </td>
            </tr>
        }
    </tbody>
</table>


<div class="modal fade" id="empleadoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="Guardar">

                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitulo">Agregar Empleado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" id="IdEmpleado" name="IdEmpleado" />

                    <div class="mb-3">
                        <label>Nombre</label>
                        <input type="text" id="Nombre" name="Nombre" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Edad</label>
                        <input type="number" id="Edad" name="Edad" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Id Departamento</label>
                        <input type="number"
                               id="IdDepartamento"
                               name="Departamento.IdDepartamento"
                               class="form-control"
                               required />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">
                        Guardar
                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        function abrirModalAgregar() {

            document.getElementById("modalTitulo").innerText = "Agregar Empleado";
            document.getElementById("IdEmpleado").value = 0;
            document.getElementById("Nombre").value = "";
            document.getElementById("Edad").value = "";
            document.getElementById("IdDepartamento").value = "";

            var modal = new bootstrap.Modal(document.getElementById('empleadoModal'));
            modal.show();
        }

        function abrirModalEditar(id, nombre, edad, idDepartamento) {

            document.getElementById("modalTitulo").innerText = "Editar Empleado";
            document.getElementById("IdEmpleado").value = id;
            document.getElementById("Nombre").value = nombre;
            document.getElementById("Edad").value = edad;
            document.getElementById("IdDepartamento").value = idDepartamento;

            var modal = new bootstrap.Modal(document.getElementById('empleadoModal'));
            modal.show();
        }

        console.log ("Funciona la verdad");

    </script>
}